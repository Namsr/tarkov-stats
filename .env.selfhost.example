# Скопируй этот файл в `.env` (рядом с docker-compose.yml) и заполни значения.
# Файл `.env` уже игнорируется гитом — секреты не утекут в репозиторий.

# Реальный Turnstile sitekey (НЕ тестовый!). Возьми в Cloudflare → Turnstile,
# и добавь свои домены (tarkovstats.ru, tarkovstats.online) в allowed-domains.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAVVIHGZCr2PPwrR

# Токен туннеля. Получишь в Cloudflare Zero Trust → Networks → Tunnels →
# создать туннель → Docker → длинная строка после `--token`.
TUNNEL_TOKEN=

# --- Вход через Google (читается контейнером web в РАНТАЙМЕ через env_file) ---

# Секрет для подписи session-JWT. Сгенерируй: openssl rand -base64 32
AUTH_SECRET=

# OAuth-клиент из Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Публичный URL сайта (без слэша на конце). За Caddy origin запроса приходит
# http/внутренним хостом, из-за чего Google ругается redirect_uri_mismatch.
# Этим значением фиксируется redirect_uri = $PUBLIC_BASE_URL/api/auth/google/callback
PUBLIC_BASE_URL=https://tarkovstats.ru

# Какой заголовок прокси содержит РЕАЛЬНЫЙ IP клиента — это ключ rate-limit, и
# доверять можно только заголовку от нашего прокси (клиентский подделывается, что
# = обход лимита). За Caddy (этот сетап) оставь x-real-ip: Caddy выставляет
# `header_up X-Real-IP {remote_host}`. Если поставишь сайт ЗА Cloudflare
# (proxied / Tunnel) — смени на cf-connecting-ip.
TRUSTED_IP_HEADER=x-real-ip
