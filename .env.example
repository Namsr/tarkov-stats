# Cloudflare Turnstile sitekey used by the verification gate.
#
# - Local dev: .env.local sets this to the "always passes" TEST key
#   (1x00000000000000000000AA) so the gate works on localhost. Note that
#   tarkov.dev's API will still 401 a test-key token, so live data only
#   works from an allowed production domain.
# - Production: set this to your real Turnstile sitekey, and add your
#   deployed domain to that sitekey's allowed-domains list in the
#   Cloudflare dashboard. If unset, the app falls back to the hardcoded
#   production key in components/TurnstileWidget.tsx.
#
# IMPORTANT: this is a NEXT_PUBLIC_ var, so it is inlined at BUILD time.
# Do not run `next build` for production on a machine where .env.local holds
# the test key, or the test key will be baked into the bundle. Build on your
# host/CI (where .env.local is absent) or set this var there explicitly.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAVVIHGZCr2PPwrR

# --- Authentication (Google sign-in) ---

# Session signing secret. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials.
# Create them at https://console.cloud.google.com
#   APIs & Services -> Credentials -> Create OAuth client ID -> Web application
# Authorized redirect URI for local dev:
#   http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
