{
	servers {
		timeouts {
			read_body   10s
			read_header 5s
			write       30s
			idle        120s
		}
		max_header_size 16kb
	}
}

(hardening) {
	header {
		# TLS терминируется здесь — HSTS отдаём сами (без preload, обратимо).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Не светим сервер/прокси.
		-Server
		-Via
	}
	# Лимит тела запроса — у нас только GET-API и мелкие POST (auth/logout).
	request_body {
		max_size 256KB
	}
	reverse_proxy web:3000 {
		# Реальный TCP-адрес пира — клиент подделать не может. Закрывает обход
		# rate-limit подменой X-Forwarded-For.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}
}

tarkovstats.ru, www.tarkovstats.ru {
	encode gzip
	import hardening
}

tarkovstats.online, www.tarkovstats.online {
	encode gzip
	import hardening
}
